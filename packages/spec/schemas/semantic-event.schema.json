{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eoreader.dev/spec/schemas/semantic-event.schema.json",
  "title": "SemanticEvent",
  "description": "Canonical append-only unit of the EOReader semantic ledger. event_id MUST be a hash of the canonical (schema_version, operator_epoch, op, site, observation_id, referents, frame, resolution, provenance, authority, inputs, payload) tuple via packages/spec/canonical-json. provenance and authority are kept as separate top-level fields deliberately (section 3.2) \u2014 neither may substitute for the other.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "operator_epoch",
    "op",
    "inputs",
    "provenance",
    "authority"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_id": {
      "type": "string",
      "pattern": "^event:sha256:[0-9a-f]{64}$"
    },
    "operator_epoch": {
      "type": "string",
      "minLength": 1
    },
    "op": {
      "type": "string",
      "enum": [
        "NUL",
        "SEG",
        "DEF",
        "SIG",
        "CON",
        "EVA",
        "INS",
        "SYN",
        "REC"
      ]
    },
    "site": {
      "type": "object"
    },
    "observation_id": {
      "type": "string"
    },
    "referents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frame": {
      "type": "object"
    },
    "resolution": {
      "type": "object"
    },
    "provenance": {
      "type": "object",
      "description": "What this event depends on: prior observations, selectors, transformations.",
      "additionalProperties": false,
      "required": [
        "depends_on"
      ],
      "properties": {
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transformations": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "description": "What entitles the observing agent to assert this event's frame/commitment.",
      "additionalProperties": false,
      "required": [
        "actor_id",
        "grant"
      ],
      "properties": {
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "grant": {
          "type": "object"
        }
      }
    },
    "inputs": {
      "type": "array",
      "description": "Causal predecessor event_ids. Canonical order is topological with deterministic tie-breaking; this array is NOT the intrinsic identity of the event, and no engine module may call Date.now() to order events.",
      "items": {
        "type": "string"
      }
    },
    "payload": {
      "type": "object"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "observation.admitted",
        "observable.proposed",
        "observable.evaluated",
        "boundary.proposed",
        "boundary.evaluated",
        "kind.proposed",
        "kind.evaluated",
        "kind.accepted",
        "kind.held",
        "kind.superseded",
        "parameter.proposed",
        "parameter.evaluated",
        "parameter.accepted",
        "transition.proposed",
        "transition.evaluated",
        "structure.lifted",
        "hypothesis.competing",
        "discovery.abstained",
        "effect.result.admitted",
        "hypothesis.superseded",
        "hypothesis.held"
      ]
    },
    "context": {
      "type": "object"
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "accepted",
        "held",
        "rejected",
        "superseded",
        "retracted"
      ]
    },
    "evidence": {
      "type": "object"
    },
    "counter_evidence": {
      "type": "object"
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_version",
        "evaluator_version",
        "evidence_split",
        "null_protocol",
        "score_components",
        "prior_snapshot",
        "run_context",
        "upstream_event_ids"
      ],
      "properties": {
        "candidate_version": {
          "type": "string"
        },
        "evaluator_version": {
          "type": "string"
        },
        "evidence_split": {
          "type": "object"
        },
        "null_protocol": {
          "type": "object"
        },
        "score_components": {
          "type": "object"
        },
        "prior_snapshot": {
          "type": "string"
        },
        "run_context": {
          "type": "object"
        },
        "upstream_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
