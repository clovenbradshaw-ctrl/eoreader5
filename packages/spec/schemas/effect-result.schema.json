{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eoreader.dev/spec/schemas/effect-result.schema.json",
  "title": "EffectResult",
  "description": "The app's answer to an EffectRequest, re-entering the engine as new input. Must carry full provenance so the engine never trusts an effect's output implicitly.",
  "type": "object",
  "additionalProperties": false,
  "required": ["effect_id", "producer", "version", "configuration_hash", "content_hash"],
  "properties": {
    "effect_id": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "configuration_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "output": { "type": "object" },
    "source": { "type": "object" },
    "provenance": { "type": "object" },
    "content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
