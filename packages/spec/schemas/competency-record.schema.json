{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eoreader.dev/spec/schemas/competency-record.schema.json",
  "title": "CompetencyRecord",
  "description": "Measured predictive performance under a declared target, horizon, scoring rule, baselines, scope, and protocol (spec section 13.2, record 22.3, invariant 7.5 'competency is scoped'). competency_gain[b] = cumulative baseline loss − cumulative candidate loss; positive means lower cumulative predictive loss than baseline b.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "candidate_id", "task_id", "baseline_ids", "scoring_rule", "scope", "observations", "proper_observations", "cumulative_loss", "baseline_losses", "competency_gain", "warrant_status", "status", "content_hash"],
  "properties": {
    "schema": { "const": "CompetencyRecord@1" },
    "id": { "type": "string" },
    "candidate_id": { "type": "string" },
    "task_id": { "type": "string" },
    "baseline_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "scoring_rule": { "type": "string" },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["horizon", "population", "source_versions", "evaluation_protocol"],
      "properties": {
        "horizon": { "type": "object" },
        "population": { "type": "string" },
        "source_versions": { "type": "array", "items": { "type": "string" } },
        "evaluation_protocol": { "type": "string" }
      }
    },
    "observations": { "type": "integer", "minimum": 0 },
    "proper_observations": { "type": "integer", "minimum": 0 },
    "cumulative_loss": { "type": "number" },
    "baseline_losses": { "type": "object", "additionalProperties": { "type": "number" } },
    "competency_gain": { "type": "object", "additionalProperties": { "type": "number" } },
    "warrant_status": { "enum": ["strong", "supported", "weak", "defeated", "unknown"] },
    "status": { "enum": ["experimental", "replicated", "failed", "invalidated"] },
    "content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
