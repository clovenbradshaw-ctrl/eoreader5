{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eoreader.dev/spec/schemas/observation-envelope.schema.json",
  "title": "ObservationEnvelope",
  "description": "ObservationEnvelope@1 normalized observation field. Decoders expose source-given axes, fields, anchors, missingness, and losses without asserting semantic kinds.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source_id",
    "source_media_type",
    "decoder",
    "axes",
    "fields",
    "anchors",
    "source_content_hash",
    "blocks_hash"
  ],
  "properties": {
    "schema": {
      "const": "ObservationEnvelope@1"
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_media_type": {
      "type": "string",
      "minLength": 1
    },
    "decoder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "loss": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "axes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "axis_id",
          "topology"
        ],
        "properties": {
          "axis_id": {
            "type": "string",
            "minLength": 1
          },
          "topology": {
            "enum": [
              "ordered",
              "categorical",
              "grid",
              "tree",
              "graph",
              "set"
            ]
          },
          "unit": {
            "type": "string"
          },
          "anchors": {
            "type": "object"
          }
        }
      }
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field_id",
          "value_type",
          "block_id"
        ],
        "properties": {
          "field_id": {
            "type": "string",
            "minLength": 1
          },
          "value_type": {
            "type": "string",
            "minLength": 1
          },
          "block_id": {
            "type": "string",
            "minLength": 1
          },
          "axes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingness": {
            "type": "object"
          },
          "loss": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "predicate_class": {
            "enum": [
              "agentive",
              "attributive",
              "patient",
              "unclassified"
            ]
          },
          "presence_role": {
            "enum": [
              "foreground",
              "present",
              "latent",
              "attributive"
            ]
          }
        }
      }
    },
    "anchors": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "scheme"
      ],
      "properties": {
        "scheme": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]+$"
    },
    "blocks_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]+$"
    }
  }
}
